---
import { sobreMi } from "../../data/about";
import TechStack from "./tech/TechStack.astro";
---

<section
  id="about"
  class="min-h-screen md:min-h-0 w-full flex items-center justify-center px-4 sm:px-6 py-16 md:py-20 overflow-x-hidden"
>
  <div class="max-w-3xl w-full">

    <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-8">
      {sobreMi.titulo}
    </h2>

    <div class="space-y-5 text-gray-400 font-normal leading-relaxed text-sm sm:text-base text-left md:text-center">
      {sobreMi.parrafos.map((parrafo) => (
        <p>{parrafo}</p>
      ))}
    </div>

    <div class="mt-10">
      <TechStack />
    </div>

  </div>
</section>
