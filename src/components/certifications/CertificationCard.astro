---
import { certifications } from "../../data/certifications"
---

<div class="flex items-center justify-between mb-4 px-2">
  <span class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Mis Logros</span>
  <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-semibold rounded-full bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 shadow-sm">
    Total: {certifications.length}
  </span>
</div>

<article 
  class="w-full mx-auto p-4 sm:p-6 bg-white/5 border border-gray-800 rounded-2xl shadow-sm hover:border-gray-700 transition flex flex-col items-center gap-4"
  aria-label="Carrusel de Certificaciones"
>
  <div class="relative w-full aspect-square sm:aspect-video overflow-hidden rounded-xl bg-zinc-50 dark:bg-zinc-950 border border-zinc-100 dark:border-zinc-850 flex items-center justify-center p-2">
    <img 
      id="cert-image" 
      src={certifications[0].image} 
      alt={`Insignia de la certificación: ${certifications[0].title}`} 
      class="max-w-full max-h-full object-contain drop-shadow-sm select-none"
      loading="eager"
    />
  </div>
  
  <header class="text-center w-full min-h-16 flex flex-col justify-center px-2">
    <h3 
      id="cert-title" 
      class="text-base sm:text-lg font-bold text-zinc-900 dark:text-zinc-50 line-clamp-2 balanced"
    >
      {certifications[0].title}
    </h3>
    <p 
      id="cert-issuer" 
      class="text-xs sm:text-sm font-medium text-zinc-500 dark:text-zinc-400 mt-1"
    >
      {certifications[0].issuer}
    </p>
  </header>

  <footer class="flex items-center justify-between sm:justify-center gap-4 sm:gap-6 w-full mt-2 pt-2 border-t border-zinc-100 dark:border-zinc-800">
    <button 
      id="prev-btn" 
      class="flex-1 sm:flex-initial inline-flex items-center justify-center px-4 py-2 text-sm font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 rounded-xl hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-95 transition-all duration-200"
      aria-label="Certificación anterior"
    >
      &larr; <span class="hidden sm:inline ml-1">Anterior</span>
    </button>
    
    <a 
      id="cert-url"
      href={certifications[0].url} 
      target="_blank" 
      rel="noopener noreferrer"
      class={`text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 hover:underline text-xs sm:text-sm font-semibold tracking-wide transition-colors whitespace-nowrap ${!certifications[0].url ? 'hidden' : ''}`}
    >
      Ver credencial
    </a>

    <button 
      id="next-btn" 
      class="flex-1 sm:flex-initial inline-flex items-center justify-center px-4 py-2 text-sm font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 rounded-xl hover:bg-zinc-200 dark:hover:bg-zinc-700 active:scale-95 transition-all duration-200"
      aria-label="Siguiente certificación"
    >
      <span class="hidden sm:inline mr-1">Siguiente</span> &rarr;
    </button>
  </footer>
</article>

<script>
  import "../certifications/carrousel.ts";
</script>
