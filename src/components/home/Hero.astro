---
import { contacts } from "../../data/contact"
---

<section class="min-h-screen md:min-h-0 w-full flex items-center justify-center px-4 sm:px-6 pt-28 pb-16 md:py-24 overflow-x-hidden">
<div class="max-w-5xl w-full flex flex-col md:flex-row items-center gap-8 md:gap-12">

    <div class="flex-1 w-full text-left">
      <p class="flex items-center gap-3 text-lg sm:text-xl md:text-2xl lg:text-3xl font-medium mb-2 text-cyan-400">
        <span>👋</span>
        Hola, soy
      </p>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-4 text-white leading-tight">
        Ernesto de la Cruz del Río
      </h1>

      <div id="role" class="text-base sm:text-lg md:text-2xl font-medium text-gray-300 tracking-wide mb-6 h-9 md:h-10 flex items-center"></div>

      <p class="mb-6 text-sm sm:text-base text-gray-400 max-w-xl">
        Construcción de interfaces web modernas con enfoque en calidad y rendimiento.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a
          href="#projects"
          class="px-5 py-2.5 bg-white text-black font-medium rounded-lg hover:opacity-90 transition text-center"
        >
          Ver proyectos
        </a>

        <a
          href="/CV_Ernesto_de_la_Cruz_Software_Developer.pdf"
          class="px-5 py-2.5 border border-gray-600 hover:bg-white/10 rounded-lg transition text-white text-center"
          download
        >
          Descargar CV
        </a>
      </div>

      <div class="flex flex-wrap justify-center sm:justify-start items-center gap-5 mt-8">
      {contacts?.map((contact) => (
        <a
          href={contact?.url}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:scale-110 transition-transform duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg"
        >
          <img
            src={contact?.icon}
            alt={`Enlace a ${contact?.name || 'contacto'}`}
            class="w-10 h-10 sm:w-12 sm:h-12 object-contain"
          />
        </a>
      ))}
      </div>
    </div>

    <div class="flex-1 flex justify-center order-first md:order-last">
      <div class="w-full max-w-56 sm:max-w-64 md:max-w-80 lg:max-w-96 aspect-square rounded-xl overflow-hidden shadow-2xl border border-white/10">
        <img
          src="/images/fotoCV.png"
          alt="Foto de Ernesto"
          loading="lazy"
          class="w-full h-full object-cover"
          />
      </div>
    </div>

  </div>
</section>

<script>
  import "../../scripts/heroRoles.ts";
</script>
