---
import { navLinks } from "../../data/navLinks"
---

<header id="navbar" class="sticky top-0 z-50 w-full border-b bg-white/80 dark:bg-black/80 backdrop-blur-md transition-colors">
    <div class="relative flex items-center justify-between px-6 py-4 w-full">
        
        <h4 class="font-bold text-lg">ECR</h4>

        <button id="menu-btn" class="md:hidden text-2xl z-50">
            ☰
        </button>

        <nav id="mobile-menu" class="hidden absolute top-full right-0 w-64 p-6 bg-white/95 dark:bg-black/95 border-l border-b border-gray-200 dark:border-gray-800 shadow-xl opacity-0 scale-95 md:opacity-100 md:scale-100 md:block md:relative md:top-auto md:right-auto md:w-auto md:p-0 md:bg-transparent md:dark:bg-transparent md:border-none md:shadow-none transition-all duration-300">
            <ul class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6 text-sm md:text-base">
                {navLinks.map((link) => (
                    <li>
                        <a class="hover:text-gray-500 dark:hover:text-gray-300 transition block py-2 md:py-0" href={link.href}>
                            {link.label}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>
        
    </div>
</header>

<script>
    import "./navbar.ts";
</script>
