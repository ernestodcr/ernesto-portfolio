---
import { projects } from "../../data/projects"
import ProjectList from "./ProjectList.astro"
---

<section
  id="projects"
  class="w-full flex flex-col items-center justify-center px-4 sm:px-6 py-16 md:py-20 overflow-x-hidden"
>
  <div class="max-w-5xl w-full flex flex-col items-center">
    
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-white">
      Proyectos
    </h2>
    
    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-6">
      <ProjectList /> 
  </div>
</section>
